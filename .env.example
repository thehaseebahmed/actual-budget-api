# Copy this file to .env and fill in your values

# Actual Budget server
ACTUAL_SERVER_URL=http://localhost:5006
ACTUAL_SERVER_PASSWORD=your-server-password

# Budget sync ID — found in Actual under Settings → Advanced
ACTUAL_BUDGET_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# End-to-end encryption password — leave blank if not using e2e encryption
ACTUAL_BUDGET_PASSWORD=

# Port this API listens on
PORT=3000
